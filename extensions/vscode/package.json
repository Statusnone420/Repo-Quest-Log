{
  "name": "repo-quest-log",
  "displayName": "Repo Quest Log",
  "description": "A local-first repo HUD for markdown-driven agent workflows.",
  "version": "0.0.2",
  "publisher": "local",
  "repository": {
    "type": "git",
    "url": "https://github.com/Statusnone420/Repo-Quest-Log.git"
  },
  "engines": {
    "vscode": "^1.96.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onView:repoQuestLog.view",
    "onCommand:repoQuestLog.refresh"
  ],
  "main": "./extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "repoQuestLog",
          "title": "Repo Quest Log",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "repoQuestLog": [
        {
          "id": "repoQuestLog.view",
          "name": "HUD",
          "type": "webview"
        }
      ]
    },
    "commands": [
      {
        "command": "repoQuestLog.refresh",
        "title": "Repo Quest Log: Refresh"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "node -e \"require('fs').cpSync('../../dist', './dist', {recursive: true, force: true})\""
  },
  "dependencies": {
    "chokidar": "^3.6.0",
    "gray-matter": "^4.0.3",
    "remark": "^15.0.1",
    "remark-parse": "^11.0.0",
    "unified": "^11.0.4"
  }
}
