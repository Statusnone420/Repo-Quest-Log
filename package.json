{
  "name": "repo-quest-log",
  "version": "0.0.2",
  "description": "Local-first companion that makes repo intent legible at a glance.",
  "type": "module",
  "bin": {
    "repolog": "./dist/cli/index.js",
    "quest-log": "./dist/cli/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/cli/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "desktop:preview": "node dist/cli/index.js desktop",
    "desktop:app": "npm run build && electron apps/desktop/main.cjs",
    "pack:vscode": "node scripts/package-vscode.cjs",
    "vscode:build": "npm run pack:vscode",
    "desktop:build": "npm run build && npm run pack:vscode && electron-builder --win --x64"
  },
  "dependencies": {
    "chokidar": "^3.6.0",
    "gray-matter": "^4.0.3",
    "ink": "^5.0.0",
    "react": "^18.3.1",
    "remark": "^15.0.1",
    "remark-parse": "^11.0.0",
    "unified": "^11.0.4"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/react": "^18.3.3",
    "@vscode/vsce": "^3.9.1",
    "electron": "^37.2.3",
    "electron-builder": "^26.8.1",
    "eslint": "^9.0.0",
    "typescript": "^5.4.0",
    "vitest": "^4.1.5"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "cli",
    "tui",
    "adhd",
    "ai-agents",
    "markdown",
    "claude-code",
    "codex"
  ],
  "license": "MIT",
  "build": {
    "appId": "com.repoquestlog.app",
    "productName": "Repo Quest Log",
    "directories": {
      "output": "release"
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ]
    },
    "files": [
      "dist/**/*",
      "apps/desktop/**/*",
      "build/**/*",
      "docs/SCHEMA.md",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "build/icon.png",
        "to": "build/icon.png"
      }
    ],
    "extraMetadata": {
      "main": "apps/desktop/main.cjs"
    }
  }
}
